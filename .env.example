# ========= 运行模式 =========
# web 或 gui。Docker 建议 web。
AUTO_REGISTER_UI_MODE=web
AUTO_REGISTER_HOST=0.0.0.0
AUTO_REGISTER_PORT=18080

# ========= 临时邮箱提供方 =========
AUTO_REGISTER_EMAIL_PROVIDER=cloudflare
CLOUDFLARE_TEMP_EMAIL_BASE_URL=https://mailcraft.icu
ADMIN_EMAIL=admin@mailcraft.icu
ADMIN_PASSWORDS=["replace-with-admin-password"]
# 可选：不填则从 ADMIN_EMAIL 推断
# CLOUDFLARE_TEMP_EMAIL_DOMAIN=mailcraft.icu

# ========= 远程认证管理 API =========
QWEN_AUTH_MODE=cli-proxy-api-remote
CLI_PROXY_API_BASE_URL=http://127.0.0.1:8056
CLI_PROXY_API_KEY=replace-with-management-key

# ========= 浏览器代理（Playwright） =========
# 优先级：QWEN_PLAYWRIGHT_PROXY > PLAYWRIGHT_PROXY > HTTPS_PROXY > HTTP_PROXY
# QWEN_PLAYWRIGHT_PROXY=http://127.0.0.1:7897
# QWEN_PLAYWRIGHT_PROXY_BYPASS=127.0.0.1,localhost,192.168.10.219
# QWEN_PLAYWRIGHT_PROXY_USERNAME=
# QWEN_PLAYWRIGHT_PROXY_PASSWORD=

# ========= 网络代理（HTTP 客户端） =========
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897
NO_PROXY=127.0.0.1,localhost,192.168.10.219

# Docker 中如需访问宿主机代理，改为：
# HTTP_PROXY=http://host.docker.internal:7897
# HTTPS_PROXY=http://host.docker.internal:7897
